# Set these in Railway → Variables. Do NOT commit a .env with real values.

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Where the WhatsApp linked-device session is stored.
# On Railway: mount a volume at /data and set this to /data/session
# so the QR pairing survives restarts and redeploys.
SESSION_PATH=/data/session

# Railway sets PORT automatically; the bot uses it for the QR web page.
# Locally, defaults to 3000.
# PORT=3000

NODE_ENV=production
