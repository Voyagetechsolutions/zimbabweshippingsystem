# Supabase Configuration (shared with the website database)
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# AI Brain (OpenAI) — required to enable the AI agent.
# Without this, the old menu flow runs as a fallback.
OPENAI_API_KEY=sk-your-new-key-here
OPENAI_MODEL=gpt-4o-mini

# Meta WhatsApp Cloud API — only needed for `npm run start:cloud`.
# From the Meta WhatsApp dashboard (API Setup / App Settings).
WHATSAPP_TOKEN=your-meta-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=pick-a-secret-phrase
WHATSAPP_APP_SECRET=your-app-secret
# WHATSAPP_GRAPH_VERSION=v21.0

# Bot Configuration
BOT_NAME=Zimbabwe Shipping Ireland
BOT_PHONE_NUMBER=+353_your_number_here

# Admin Configuration
ADMIN_PHONE_NUMBERS=+353123456789,+353987654321

# Session Configuration
SESSION_PATH=./whatsapp-session

# Environment
NODE_ENV=production
